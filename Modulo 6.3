      "source": [
        "# Importamos el método association_rules de la biblioteca MLXTEND\n",
        "from mlxtend.frequent_patterns import association_rules\n",
        "\n",
        "# Indicamos un umbral de confianza mínima para las reglas de 0,85\n",
        "reglas_asociacion = association_rules(itemsets_frecuentes, metric=\"confidence\", min_threshold=0.85)\n",
        "\n",
        "print('%d reglas generadas.' % (len(reglas_asociacion)))"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "317 reglas generadas.\n"
