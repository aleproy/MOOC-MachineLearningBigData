            "0            normal-like  MIR.type.3               2.0  \n",
            "1  CpG island-methylated  MIR.type.2               4.0  \n",
            "2            normal-like  MIR.type.1               5.0  \n",
            "3        hypo-methylated  MIR.type.2               2.0  \n",
