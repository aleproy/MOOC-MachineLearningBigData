        "id": "coH5eknwK-qQ"
      },
      "source": [
        "<figure>\n",
        "<center>\n",
        "<img src='https://drive.google.com/uc?id=1WniGr65RCjGE5BHnBby9ksDPWN8uBeXP' width=600/>\n",
